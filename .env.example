# Copy to .env and fill in. Required for server/run and make dev.

# ─── PostgreSQL (required) ───────────────────────────────────────────────────
# Match docker-compose: make db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=sding
POSTGRES_USER=sding
POSTGRES_PASSWORD=sding_dev

# ─── Auth & encryption (optional, have dev defaults) ────────────────────────
# JWT_SECRET=change-me-in-production
# JWT_TOKEN_EXPIRE_SECONDS=2592000
# LLM_ENCRYPTION_KEY=change-me-in-production-32-bytes

# ─── Server (optional) ─────────────────────────────────────────────────────
# HOST=0.0.0.0
# PORT=8080
# ALLOWED_ORIGINS=*

# ─── Search (optional) ──────────────────────────────────────────────────────
# LANGSEARCH_API_KEY=
# EXA_API_KEY=

# ─── Logging (optional) ─────────────────────────────────────────────────────
# LOG_LEVEL=INFO
# LOG_FORMAT=json
